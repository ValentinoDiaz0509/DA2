  "rule_examples": [
    {
      "name": "High Heart Rate Critical",
      "description": "Alert when heart rate exceeds 120 BPM",
      "rule": {
        "metricName": "heart_rate",
        "operator": "GREATER_THAN",
        "threshold": 120.0,
        "durationSeconds": 300,
        "severity": "CRITICAL",
        "description": "Patient heart rate is critically elevated",
        "enabled": true
      }
    },
    {
      "name": "Low Oxygen Saturation",
      "description": "Alert when SpO2 drops below 94%",
      "rule": {
        "metricName": "spo2",
        "operator": "LESS_THAN",
        "threshold": 94.0,
        "durationSeconds": 60,
        "severity": "CRITICAL",
        "description": "Patient oxygen saturation is critically low",
        "enabled": true
      }
    },
    {
      "name": "High Blood Pressure Warning",
      "description": "Alert when systolic pressure exceeds 140 mmHg",
      "rule": {
        "metricName": "systolic_pressure",
        "operator": "GREATER_THAN",
        "threshold": 140.0,
        "durationSeconds": 600,
        "severity": "WARNING",
        "description": "Patient systolic pressure is elevated",
        "enabled": true
      }
    },
    {
      "name": "Low Blood Pressure",
      "description": "Alert when systolic pressure drops below 90 mmHg",
      "rule": {
        "metricName": "systolic_pressure",
        "operator": "LESS_THAN",
        "threshold": 90.0,
        "durationSeconds": 120,
        "severity": "WARNING",
        "description": "Patient systolic pressure is dangerously low",
        "enabled": true
      }
    },
    {
      "name": "Fever Detection",
      "description": "Alert when temperature exceeds 38.5°C",
      "rule": {
        "metricName": "temperature",
        "operator": "GREATER_THAN",
        "threshold": 38.5,
        "durationSeconds": 300,
        "severity": "WARNING",
        "description": "Patient has high fever",
        "enabled": true
      }
    },
    {
      "name": "Hypothermia Alert",
      "description": "Alert when temperature drops below 35°C",
      "rule": {
        "metricName": "temperature",
        "operator": "LESS_THAN",
        "threshold": 35.0,
        "durationSeconds": 120,
        "severity": "CRITICAL",
        "description": "Patient has hypothermia (dangerously low body temperature)",
        "enabled": true
      }
    },
    {
      "name": "Bradycardia (Low Heart Rate)",
      "description": "Alert when heart rate drops below 50 BPM",
      "rule": {
        "metricName": "heart_rate",
        "operator": "LESS_THAN",
        "threshold": 50.0,
        "durationSeconds": 180,
        "severity": "CRITICAL",
        "description": "Patient has dangerously low heart rate",
        "enabled": true
      }
    },
    {
      "name": "Hypertension Stage 2",
      "description": "Alert when diastolic pressure exceeds 95 mmHg",
      "rule": {
        "metricName": "diastolic_pressure",
        "operator": "GREATER_THAN_OR_EQUAL",
        "threshold": 95.0,
        "durationSeconds": 600,
        "severity": "WARNING",
        "description": "Patient diastolic pressure indicates stage 2 hypertension",
        "enabled": true
      }
    }
  ],
